# TruthLens — copy to .env and fill values. Never commit .env.

# Backend API (used by Streamlit and Telegram bot)
BACKEND_URL=http://localhost:8000

# NewsAPI (https://newsapi.org)
NEWSAPI_KEY=your_newsapi_key

# OpenAI (LangChain RAG, CrewAI)
OPENAI_API_KEY=your_openai_api_key

# Telegram Bot (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# MLflow (optional; default tracks to ./mlruns)
MLFLOW_TRACKING_URI=file:./mlruns

# Database (optional for MVP; use for production)
# DATABASE_URL=postgresql://user:pass@host:5432/truthlens
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=your_supabase_service_key

# Environment
ENV=development
